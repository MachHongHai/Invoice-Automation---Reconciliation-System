{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Invoice Metadata",
  "type": "object",
  "required": ["invoice_code", "invoice_number", "invoice_date", "vendor_id", "subtotal", "vat_amount", "total_amount", "currency", "expected_case"],
  "properties": {
    "invoice_code": { "type": "string" },
    "invoice_number": { "type": "string" },
    "invoice_series": { "type": "string" },
    "invoice_template_code": { "type": "string" },
    "invoice_date": { "type": "string", "format": "date" },
    "due_date": { "type": "string", "format": "date" },
    "vendor_id": { "type": "string" },
    "vendor_name": { "type": "string" },
    "vendor_tax_code": { "type": "string" },
    "buyer_name": { "type": "string" },
    "buyer_tax_code": { "type": "string" },
    "subtotal": { "type": "number", "minimum": 0 },
    "vat_rate": { "type": "number", "minimum": 0 },
    "vat_amount": { "type": "number", "minimum": 0 },
    "total_amount": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "enum": ["VND"] },
    "invoice_type": { "type": "string" },
    "ocr_difficulty": { "type": "string", "enum": ["clean", "slightly_noisy", "no_accent", "layout_variant", "low_confidence"] },
    "expected_case": { "type": "string" }
  }
}

