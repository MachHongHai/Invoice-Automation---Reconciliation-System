{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bank Statement",
  "type": "object",
  "required": ["transaction_id", "transaction_date", "description", "amount", "direction", "currency"],
  "properties": {
    "transaction_id": { "type": "string" },
    "transaction_date": { "type": "string", "format": "date" },
    "value_date": { "type": "string", "format": "date" },
    "account_number": { "type": "string" },
    "description": { "type": "string" },
    "amount": { "type": "number", "minimum": 0 },
    "direction": { "type": "string", "enum": ["inflow", "outflow"] },
    "currency": { "type": "string", "enum": ["VND"] },
    "balance_after": { "type": "number" },
    "counterparty_name": { "type": "string" },
    "counterparty_account": { "type": "string" },
    "reference_code": { "type": "string" },
    "expected_case": { "type": "string" }
  }
}

