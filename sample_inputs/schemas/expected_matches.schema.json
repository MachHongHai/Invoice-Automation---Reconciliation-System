{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Expected Reconciliation Matches",
  "type": "object",
  "required": ["invoice_code", "invoice_number", "expected_status"],
  "properties": {
    "invoice_code": { "type": "string" },
    "invoice_number": { "type": "string" },
    "expected_transaction_id": { "type": "string" },
    "expected_status": {
      "type": "string",
      "enum": ["matched", "partially_matched", "amount_mismatch", "unmatched_invoice", "unmatched_transaction", "duplicate_invoice", "vendor_mismatch", "date_mismatch", "needs_review"]
    },
    "expected_exception_type": { "type": "string" },
    "expected_amount_diff": { "type": "number" },
    "expected_date_diff_days": { "type": "number" },
    "notes": { "type": "string" }
  }
}

