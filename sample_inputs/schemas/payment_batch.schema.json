{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "payment_batch",
  "type": "object",
  "required": ["payment_id", "invoice_id", "approved_amount", "approval_status"],
  "properties": {
    "payment_id": { "type": "string" },
    "invoice_id": { "type": "string" },
    "vendor_id": { "type": "string" },
    "scheduled_payment_date": { "type": "string" },
    "approved_amount": { "type": ["number", "string"] },
    "currency": { "type": "string" },
    "approval_status": {
      "type": "string",
      "enum": ["draft", "needs_review", "approved", "rejected", "paid", "reconciled", "exception"]
    },
    "approved_by": { "type": "string" },
    "approved_at": { "type": "string" },
    "payment_method": { "type": "string" },
    "notes": { "type": "string" }
  }
}
