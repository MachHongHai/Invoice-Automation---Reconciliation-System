{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OCR Ground Truth",
  "type": "object",
  "required": ["invoice_code", "file_name", "expected_invoice_number", "expected_vendor_name", "expected_invoice_date", "expected_total_amount", "expected_currency"],
  "properties": {
    "invoice_code": { "type": "string" },
    "file_name": { "type": "string" },
    "expected_invoice_number": { "type": "string" },
    "expected_vendor_name": { "type": "string" },
    "expected_vendor_tax_code": { "type": "string" },
    "expected_invoice_date": { "type": "string", "format": "date" },
    "expected_subtotal": { "type": "number" },
    "expected_vat_amount": { "type": "number" },
    "expected_total_amount": { "type": "number" },
    "expected_currency": { "type": "string", "enum": ["VND"] },
    "expected_ocr_difficulty": { "type": "string" }
  }
}

