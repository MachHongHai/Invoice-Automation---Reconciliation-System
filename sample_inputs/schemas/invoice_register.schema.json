{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "invoice_register",
  "type": "object",
  "required": ["invoice_id", "invoice_number", "invoice_date", "vendor_id", "total_amount", "currency"],
  "properties": {
    "invoice_id": { "type": "string" },
    "invoice_number": { "type": "string" },
    "invoice_series": { "type": "string" },
    "invoice_template_code": { "type": "string" },
    "invoice_date": { "type": "string", "format": "date" },
    "due_date": { "type": "string" },
    "vendor_id": { "type": "string" },
    "vendor_name": { "type": "string" },
    "vendor_tax_code": { "type": "string" },
    "vendor_bank_account": { "type": "string" },
    "subtotal": { "type": ["number", "string"] },
    "vat_rate": { "type": ["number", "string"] },
    "vat_amount": { "type": ["number", "string"] },
    "total_amount": { "type": ["number", "string"] },
    "currency": { "type": "string" },
    "invoice_status": { "type": "string" },
    "source_type": { "type": "string" },
    "attachment_file": { "type": "string" },
    "expected_case": { "type": "string" }
  }
}
