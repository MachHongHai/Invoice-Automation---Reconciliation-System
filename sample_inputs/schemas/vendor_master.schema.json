{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vendor Master",
  "type": "object",
  "required": ["vendor_id", "vendor_name", "tax_code", "bank_account", "status"],
  "properties": {
    "vendor_id": { "type": "string" },
    "vendor_name": { "type": "string" },
    "vendor_short_name": { "type": "string" },
    "tax_code": { "type": "string", "pattern": "^[0-9]{10,13}$" },
    "bank_account": { "type": "string" },
    "address": { "type": "string" },
    "email": { "type": "string" },
    "phone": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["software", "office_supply", "logistics", "marketing", "cloud", "cleaning", "warehouse", "maintenance", "security", "consulting"]
    },
    "status": { "type": "string", "enum": ["active", "inactive"] }
  }
}

