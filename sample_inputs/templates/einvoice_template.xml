<?xml version="1.0" encoding="UTF-8"?>
<HDon>
  <DLHDon>
    <TTChung>
      <PBan>2.0.1</PBan>
      <THDon>{{ invoice_title }}</THDon>
      <KHMSHDon>{{ invoice_template_code }}</KHMSHDon>
      <KHHDon>{{ invoice_series }}</KHHDon>
      <SHDon>{{ invoice_number }}</SHDon>
      <NLap>{{ invoice_date }}</NLap>
      <DVTTe>{{ currency }}</DVTTe>
      <TGia>1</TGia>
      <HTTToan>TM/CK</HTTToan>
    </TTChung>
    <NDHDon>
      <NBan>
        <Ten>{{ vendor_name }}</Ten>
        <MST>{{ vendor_tax_code }}</MST>
        <DChi>{{ vendor_address }}</DChi>
        <STKNHang>{{ vendor_bank_account }}</STKNHang>
        <TNHang>{{ vendor_bank_name }}</TNHang>
      </NBan>
      <NMua>
        <Ten>{{ buyer_name }}</Ten>
        <MST>{{ buyer_tax_code }}</MST>
      </NMua>
      <DSHHDVu>
        <HHDVu>
          <TChat>1</TChat>
          <STT>1</STT>
          <THHDVu>{{ item_name }}</THHDVu>
          <DVTinh>Lo</DVTinh>
          <SLuong>1</SLuong>
          <DGia>{{ subtotal }}</DGia>
          <ThTien>{{ subtotal }}</ThTien>
          <TSuat>{{ vat_rate_text }}</TSuat>
          <TThue>{{ vat_amount }}</TThue>
        </HHDVu>
      </DSHHDVu>
      <TToan>
        <TgTCThue>{{ subtotal }}</TgTCThue>
        <TgTThue>{{ vat_amount }}</TgTThue>
        <TgTTTBSo>{{ total_amount }}</TgTTTBSo>
        <TgTTTBChu>{{ total_amount_words }}</TgTTTBChu>
      </TToan>
    </NDHDon>
  </DLHDon>
  <MCCQT>{{ tax_authority_code }}</MCCQT>
</HDon>
